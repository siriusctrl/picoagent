{
  "name": "picoagent",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "pico": "dist/clients/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/clients/cli/main.js serve",
    "start:tui": "node dist/clients/tui/main.js",
    "start:cli": "node dist/clients/cli/main.js",
    "dev": "npx tsx src/clients/cli/main.ts serve",
    "dev:cli": "npx tsx src/clients/cli/main.ts",
    "dev:tui": "npx tsx src/clients/tui/main.tsx",
    "dev:http": "npx tsx src/clients/cli/main.ts serve",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "npx tsc -p tsconfig.check.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/genai": "^1.40.0",
    "@types/react": "^19.2.14",
    "ink": "^7.0.0",
    "openai": "^6.19.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
